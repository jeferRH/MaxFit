<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

  <display-name>MaxFit Web</display-name>

  <welcome-file-list>
    <welcome-file>index.jsp</welcome-file>
  </welcome-file-list>

  <!-- Capa controlador (C de MVC): rutas públicas → forwards a WEB-INF/vistas -->

  <servlet>
    <servlet-name>InicioController</servlet-name>
    <servlet-class>com.maxfit.controller.InicioController</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>InicioController</servlet-name>
    <url-pattern>/inicio</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>EjemploController</servlet-name>
    <servlet-class>com.maxfit.controller.EjemploController</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>EjemploController</servlet-name>
    <url-pattern>/ejemplo</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>PruebaConexionBdController</servlet-name>
    <servlet-class>com.maxfit.controller.PruebaConexionBdController</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>PruebaConexionBdController</servlet-name>
    <url-pattern>/dev/prueba-bd</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>LoginController</servlet-name>
    <servlet-class>com.maxfit.controller.LoginController</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>LoginController</servlet-name>
    <url-pattern>/login</url-pattern>
  </servlet-mapping>
</web-app>
